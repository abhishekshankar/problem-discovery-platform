# G2
G2_API_KEY=
G2_BASE_URL=https://data.g2.com
# token | bearer | query
G2_AUTH_SCHEME=token
# syndication | survey
G2_MODE=syndication
# Comma-separated G2 product IDs
G2_PRODUCT_IDS=

# HasData (Indeed)
HASDATA_API_KEY=
HASDATA_BASE_URL=https://api.hasdata.com
INDEED_LOCATION=United States
INDEED_COUNTRY=us
INDEED_DOMAIN=www.indeed.com
INDEED_SORT=date

# Reddit (PRAW live deltas)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=problem-discovery-ivf/1.0
